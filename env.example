# 环境变量配置模板
# 复制本文件为 .env 并填入实际值
# ⚠️ 永远不要提交 .env 文件到Git！

# ============================================
# 应用配置
# ============================================
APP_NAME=智能体脂分析仪
APP_ENV=development
DEBUG=true

# 后端服务配置
HOST=0.0.0.0
PORT=8000

# ============================================
# STM32 串口配置
# ============================================
# Windows: COM3, COM4 等
# Linux: /dev/ttyUSB0, /dev/ttyACM0 等
# macOS: /dev/cu.usbserial-XXXX
SERIAL_PORT=/dev/ttyUSB0
BAUDRATE=115200

# ============================================
# AI API 配置（必须配置）
# ============================================
# DeepSeek API (推荐，中文效果好)
DEEPSEEK_API_KEY=sk-your-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 备选：OpenAI API（如需使用请取消注释）
# OPENAI_API_KEY=sk-your-openai-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1

# ============================================
# 数据库配置（可选，默认使用SQLite）
# ============================================
DATABASE_URL=sqlite:///./data/body_scale.db
# PostgreSQL示例: postgresql://user:password@localhost/body_scale

# ============================================
# 日志配置
# ============================================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
